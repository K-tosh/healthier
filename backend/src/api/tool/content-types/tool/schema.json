{
  "kind": "collectionType",
  "collectionName": "tools",
  "info": {
    "singularName": "tool",
    "pluralName": "tools",
    "displayName": "tools",
    "description": "Health tools, calculators and trackers"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "toolName": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "slug": {
      "type": "uid"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "BMI Calculator",
        "Ovulation Calculator",
        "Cold And Flu Map",
        "Pill Identifier",
        "Drug Interaction",
        "Calorie Counter",
        "Pregnancy Timeline"
      ],
      "required": true
    },
    "toolType": {
      "type": "enumeration",
      "enum": [
        "e.g.",
        "BMI",
        "Due Date",
        "etc"
      ]
    },
    "embedCode": {
      "type": "blocks"
    },
    "featured": {
      "type": "boolean"
    },
    "thumbnail": {
      "allowedTypes": [
        "images",
        "videos",
        "audios",
        "files"
      ],
      "type": "media",
      "multiple": false
    }
  }
}
