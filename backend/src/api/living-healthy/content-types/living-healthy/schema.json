{
  "kind": "collectionType",
  "collectionName": "living_healthy_categories",
  "info": {
    "singularName": "living-healthy",
    "pluralName": "living-healthy-categories",
    "displayName": "Living Healthy",
    "description": "Categories for living healthy section"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "livingHealthyCategory"
    }
  }
} 