{
  "kind": "singleType",
  "collectionName": "homepages",
  "info": {
    "singularName": "homepage",
    "pluralName": "homepages",
    "displayName": "homepage",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article"
    },
    "authors": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::author.author"
    },
    "tools": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tool.tool"
    },
    "seo": {
      "type": "string"
    },
    "seo_descreption": {
      "type": "string"
    },
    "heroTitle": {
      "type": "string"
    },
    "heroSubtitle": {
      "type": "string"
    },
    "cover": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "wellness_articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::wellness-article.wellness-article"
    },
    "wellnessTitle": {
      "type": "string"
    },
    "featuredConditionsTitle": {
      "type": "string"
    },
    "conditions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::condition.condition"
    },
    "promoText": {
      "type": "blocks"
    },
    "promoLInk": {
      "type": "string"
    },
    "promoImage": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
